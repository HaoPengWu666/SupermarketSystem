  </property>
  <property name="windowTitle">
   <string>超市销售管理系统</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* 主窗口背景 */
QMainWindow {
    background-color: #f0f0f0;
}

/* 左侧导航区域 */
#centralwidget {
    background-color: #2c3e50;
}

/* 左侧导航按钮 - 综合改进 */
QToolButton {
    background-color: #3498db;
    color: white;
    border: none;
    padding: 12px 12px 12px 20px;
    font-size: 14px;
    border-radius: 4px;
    margin: 5px;
    text-align: left;
    min-width: 120px;
    transition: all 0.1s ease;  /* 添加平滑过渡效果 */
}

QToolButton:hover {
    background-color: #2980b9;
    padding-left: 22px;  /* 悬停时轻微右移 */
}

QToolButton:pressed {
    background-color: #154360;  /* 更深的蓝色 */
    color: #ecf0f1;
    border-left: 3px solid #f39c12;
    padding-left: 17px;  /* 保持总间距不变 */
    box-shadow: inset 2px 2px 4px rgba(0,0,0,0.2);
}

/* 当前选中按钮的特殊样式 */
QToolButton:checked {
    background-color: #1a5276;
    font-weight: bold;
    border-left: 3px solid #f1c40f;  /* 添加左侧高亮边框 */
}

#btnLogout:hover {
    background-color: #c0392b;
}

/* 内容区域标题 */
QLabel[text^=&quot;&lt;html&gt;&quot;] {
    color: #2c3e50;
    font-size: 16px;
}

/* 表格样式 */
QTableView {
    background-color: white;
    border: 1px solid #ddd;
    gridline-color: #eee;
    selection-background-color: #3498db;
    selection-color: white;
    font-size: 12px;
}

QTableView::item {
    padding: 8px;
}

QHeaderView::section {
    background-color: #3498db;
    color: white;
    padding: 8px;
    border: none;
    font-size: 12px;
}

/* 输入框样式 */
QLineEdit, QComboBox, QDateEdit {
    border: 1px solid #ddd;
    border-radius: 3px;
    padding: 8px;
    font-size: 13px;
    min-height: 30px;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 25px;
    border-left-width: 1px;
    border-left-color: #ddd;
    border-left-style: solid;
}

/* 按钮样式 */
QPushButton {
    background-color: #3498db;
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 4px;
    font-size: 13px;
    min-width: 100px;
    min-height: 30px;
}

QPushButton:hover {
    background-color: #2980b9;
}

QPushButton:pressed {
    background-color: #1a5276;
}

/* 复选框样式 */
QCheckBox {
    spacing: 8px;
    font-size: 13px;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
}

/* 状态栏 */
QStatusBar {
    background-color: #ecf0f1;
    color: #7f8c8d;
    font-size: 12px;
    padding: 5px;
}

/* 分组框 */
QGroupBox {
    border: 1px solid #ddd;
    border-radius: 3px;
    margin-top: 15px;
    font-size: 13px;
    font-weight: bold;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 15px;
    padding: 0 5px;
}

/* 堆叠页面背景 */
QStackedWidget {
    background-color: white;
    border: 1px solid #ddd;
    border-radius: 5px;
    margin: 10px;
}

/* 销售页面购物车区域 */
#tblCart {
    background-color: #f9f9f9;
    border-top: 2px solid #3498db;
}

/* 销售页面商品列表 */
#tblProducts {
    background-color: #f9f9f9;
    border-top: 2px solid #2ecc71;
}

/* 会员信息表格 */
#tblMember_m {
    background-color: #f9f9f9;
    border-top: 2px solid #9b59b6;
}

/* 会员消费统计表格 */
#tblMemberStats_m {
    background-color: #f9f9f9;
    border-top: 2px solid #e67e22;
}

/* 报表数据表格 */
#tblReport {
    background-color: #f9f9f9;
    border-top: 2px solid #1abc9c;
}

/* 库存表格 */
#tblInventory_in {
    background-color: #f9f9f9;
    border-top: 2px solid #f1c40f;
}

/* 库存预警表格 */
#tblWarning_in {
    background-color: #fff8e1;
    border-top: 2px solid #e74c3c;
}</string>
